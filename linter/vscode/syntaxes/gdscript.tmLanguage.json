{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GDScript",
  "scopeName": "source.gdscript",
  "patterns": [
    { "include": "#comment" },
    { "include": "#strings" },
    { "include": "#nodepath" },
    { "include": "#annotation" },
    { "include": "#keywords" },
    { "include": "#control" },
    { "include": "#storage" },
    { "include": "#constant" },
    { "include": "#builtin-types" },
    { "include": "#builtin-functions" },
    { "include": "#self" },
    { "include": "#function-definition" },
    { "include": "#class-definition" },
    { "include": "#signal-definition" },
    { "include": "#variable-definition" },
    { "include": "#number" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.gdscript",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.gdscript",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.gdscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.gdscript", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.gdscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.gdscript", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.other.node-path.gdscript",
          "match": "\\&\"[^\"]*\""
        }
      ]
    },
    "nodepath": {
      "patterns": [
        {
          "name": "string.interpolated.nodepath.gdscript",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_/]*"
        }
      ]
    },
    "annotation": {
      "patterns": [
        {
          "name": "entity.name.function.decorator.gdscript",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.gdscript",
          "match": "\\b(if|elif|else|for|while|match|when|break|continue|pass|return|await|yield)\\b"
        },
        {
          "name": "keyword.operator.logical.gdscript",
          "match": "\\b(and|or|not|in|is|as)\\b"
        }
      ]
    },
    "control": {
      "patterns": [
        {
          "name": "keyword.control.import.gdscript",
          "match": "\\b(class_name|extends|preload|load)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.gdscript",
          "match": "\\b(var|const|enum|signal|func|static|class)\\b"
        },
        {
          "name": "storage.modifier.gdscript",
          "match": "\\b(export|onready|setget|tool)\\b"
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "name": "constant.language.gdscript",
          "match": "\\b(true|false|null|self|super|PI|TAU|INF|NAN)\\b"
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "support.type.gdscript",
          "match": "\\b(void|bool|int|float|String|StringName|NodePath|Vector2|Vector2i|Vector3|Vector3i|Vector4|Vector4i|Rect2|Rect2i|Transform2D|Transform3D|Basis|Quaternion|AABB|Plane|Color|RID|Object|Node|Resource|Array|Dictionary|PackedByteArray|PackedInt32Array|PackedInt64Array|PackedFloat32Array|PackedFloat64Array|PackedStringArray|PackedVector2Array|PackedVector3Array|PackedColorArray|PackedVector4Array|Callable|Signal|Projection)\\b"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.gdscript",
          "match": "\\b(print|print_rich|prints|printt|print_verbose|printerr|push_error|push_warning|assert|range|len|abs|sign|clamp|clampf|clampi|lerp|lerpf|inverse_lerp|remap|min|max|minf|maxf|mini|maxi|ceil|floor|round|snapped|snappedf|snappedi|pow|sqrt|fmod|fposmod|posmod|step_decimals|move_toward|deg_to_rad|rad_to_deg|linear_to_db|db_to_linear|is_equal_approx|is_zero_approx|is_finite|is_inf|is_nan|typeof|type_string|str|int|float|bool|weakref|instance_from_id|is_instance_valid|is_instance_id_valid)\\b"
        }
      ]
    },
    "self": {
      "patterns": [
        {
          "name": "variable.language.self.gdscript",
          "match": "\\b(self|super)\\b"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.gdscript" },
            "2": { "name": "entity.name.function.gdscript" }
          }
        }
      ]
    },
    "class-definition": {
      "patterns": [
        {
          "match": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.class.gdscript" },
            "2": { "name": "entity.name.type.class.gdscript" }
          }
        },
        {
          "match": "\\b(class_name)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.import.gdscript" },
            "2": { "name": "entity.name.type.class.gdscript" }
          }
        },
        {
          "match": "\\b(extends)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.import.gdscript" },
            "2": { "name": "entity.name.type.class.gdscript" }
          }
        }
      ]
    },
    "signal-definition": {
      "patterns": [
        {
          "match": "\\b(signal)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.gdscript" },
            "2": { "name": "entity.name.function.signal.gdscript" }
          }
        }
      ]
    },
    "variable-definition": {
      "patterns": [
        {
          "match": "\\b(var|const)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.gdscript" },
            "2": { "name": "variable.other.gdscript" }
          }
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.hex.gdscript",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.gdscript",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.float.gdscript",
          "match": "\\b[0-9][0-9_]*(\\.[0-9_]+)?([eE][+-]?[0-9_]+)?\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.gdscript" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.gdscript",
          "match": "->|:=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|\\*\\*=|==|!=|<=|>=|&&|\\|\\||<<|>>|\\*\\*|[+\\-*/%&|^~<>!=]"
        },
        {
          "name": "keyword.operator.arrow.gdscript",
          "match": "->"
        }
      ]
    }
  }
}

#!/usr/bin/env python
"""
SCsub for the standalone GDScript linter.
Produces a separate homot-linter binary that links only the minimum set
of engine libraries, using stubs for ClassDB/Engine/ProjectSettings/
ResourceLoader/ScriptServer.

To enable, add to root SConstruct after the platform SCsub line:
    if env.get("linter", False):
        SConscript("linter/SCsub")

Build with (alongside an editor build — reuses editor libs, ~145MB):
    scons platform=windows target=editor linter=yes

For minimal binary size (~40-60MB, requires separate lib build):
    scons platform=windows target=template_debug linter=yes
"""
from misc.utility.scons_hints import *

Import("env")

env_linter = env.Clone()

# The linter stubs redefine symbols already present in core.lib.
# On MSVC: /FORCE:MULTIPLE allows multiple definitions (stub wins as first-seen).
# On MinGW/GCC: --allow-multiple-definition achieves the same.
if env_linter.msvc:
    env_linter.Append(LINKFLAGS=["/FORCE:MULTIPLE"])
else:
    env_linter.Append(LINKFLAGS=["-Wl,--allow-multiple-definition"])

# Remove the custom entry point set by the platform build — the linter has
# its own standard main().
linkflags = env_linter["LINKFLAGS"]
if env_linter.msvc:
    env_linter["LINKFLAGS"] = [f for f in linkflags if "ENTRY" not in str(f)]
else:
    env_linter["LINKFLAGS"] = [f for f in linkflags if "--entry" not in str(f)]

# The linter is a console application.
if env_linter.msvc:
    linkflags = env_linter["LINKFLAGS"]
    env_linter["LINKFLAGS"] = [
        "/SUBSYSTEM:CONSOLE" if "SUBSYSTEM:WINDOWS" in str(f) else f
        for f in linkflags
    ]

# --- Aggressive linker optimization ---
# /OPT:REF  — remove unreferenced functions/data (may be inhibited by /FORCE)
# /OPT:ICF  — fold identical functions (engine uses /OPT:NOICF for speed_trace)
# /DEBUG:NONE — strip all debug info from the linter binary
if env_linter.msvc:
    # Remove conflicting flags first.
    env_linter["LINKFLAGS"] = [
        f for f in env_linter["LINKFLAGS"]
        if str(f) not in ("/OPT:NOICF", "/OPT:NOREF", "/DEBUG:FULL")
    ]
    env_linter.Append(LINKFLAGS=["/OPT:REF", "/OPT:ICF", "/DEBUG:NONE"])
else:
    env_linter.Append(LINKFLAGS=["-Wl,--gc-sections", "-s"])

# --- Optimize for size ---
# Override optimization flags for the linter binary regardless of the
# engine's build configuration.
if env_linter.msvc:
    ccflags = env_linter["CCFLAGS"]
    # Replace /O2 (speed) with /Os (size), remove /Ob2 (aggressive inlining).
    env_linter["CCFLAGS"] = [
        "/Os" if (str(f) in ("/O2", "/Ox")) else f
        for f in ccflags
        if str(f) != "/Ob2"
    ]
else:
    ccflags = env_linter["CCFLAGS"]
    env_linter["CCFLAGS"] = [
        "-Os" if str(f) in ("-O2", "-O3") else f
        for f in ccflags
    ]

# --- Minimal LIBS: only core + drivers + servers + gdscript + holymolly ---
# Drop scene, editor, and unrelated modules to keep the binary small.
# Required:
#   core           — Variant, String, Object, FileAccess, etc.
#   drivers        — FileAccess/DirAccess platform implementations
#   servers        — TextServerDummy (needed by the GDScript tokenizer)
#   module_gdscript — GDScriptParser, GDScriptAnalyzer, GDScriptCache
#   module_holymolly — HOMOT language extensions
keep_names = {
    "core",
    "drivers",
    "servers",
    "module_gdscript",
    "module_holymolly",
}

old_libs = env_linter["LIBS"]
new_libs = []
for lib in old_libs:
    # LIBS entries can be SCons File nodes (lists) or plain strings.
    # Flatten to get the actual path string.
    if isinstance(lib, list):
        s = str(lib[0]) if lib else ""
    else:
        s = str(lib)

    # Keep engine libs that match our allowlist.
    is_engine_lib = ".windows." in s and s.endswith(".lib")
    if is_engine_lib:
        keep = any(name + "." in s.replace("\\", "/").split("/")[-1] for name in keep_names)
        if keep:
            new_libs.append(lib)
    else:
        # System/third-party libs — keep all of them.
        new_libs.append(lib)

env_linter["LIBS"] = new_libs

linter_sources = []

# Compile linter-specific source files.
env_linter.add_source_files(linter_sources, "main_linter.cpp")
env_linter.add_source_files(linter_sources, "linter_run.cpp")
env_linter.add_source_files(linter_sources, "stubs/*.cpp")

# Build as a separate program.
# The linter_sources (stub .obj files) are listed first so their symbols
# take precedence over the same symbols in the engine static libraries.
prog = env_linter.add_program("#bin/homot-linter", linter_sources)

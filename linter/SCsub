#!/usr/bin/env python
"""
SCsub for the homot toolchain (lint + lsp + lspa, unified binary).

Produces a single `homot` binary with subcommands:
    homot lint <path> [<path>...]   — GDScript linter
    homot lsp                       — GDScript Language Server (stdio)
    homot lspa                      — Language Server for Agents (stdio)

The binary embeds a compressed copy of linterdb.json so no external
database file is needed at runtime. Use --db to override.

Build with:
    scons platform=windows target=template_debug linter=yes
"""
from misc.utility.scons_hints import *

Import("env")

import os
import subprocess
import sys

env_homot = env.Clone()

# Define HOMOT_LINTER so the engine source files compile with stub logic.
env_homot.Append(CPPDEFINES=["HOMOT_LINTER"])

# Remove the custom entry point set by the platform build — homot has
# its own standard main().
linkflags = env_homot["LINKFLAGS"]
if env_homot.msvc:
    env_homot["LINKFLAGS"] = [f for f in linkflags if "ENTRY" not in str(f)]
else:
    env_homot["LINKFLAGS"] = [f for f in linkflags if "--entry" not in str(f)]

# Console application.
if env_homot.msvc:
    linkflags = env_homot["LINKFLAGS"]
    env_homot["LINKFLAGS"] = [
        "/SUBSYSTEM:CONSOLE" if "SUBSYSTEM:WINDOWS" in str(f) else f
        for f in linkflags
    ]

# --- Linker optimization ---
if env_homot.msvc:
    env_homot["LINKFLAGS"] = [
        f for f in env_homot["LINKFLAGS"]
        if str(f) not in ("/OPT:NOICF", "/OPT:NOREF", "/DEBUG:FULL")
    ]
    env_homot.Append(LINKFLAGS=["/OPT:REF", "/OPT:ICF", "/DEBUG:NONE"])
else:
    env_homot.Append(LINKFLAGS=["-Wl,--gc-sections", "-s"])

# --- Optimize for size ---
if env_homot.msvc:
    ccflags = env_homot["CCFLAGS"]
    env_homot["CCFLAGS"] = [
        "/Os" if (str(f) in ("/O2", "/Ox")) else f
        for f in ccflags
        if str(f) != "/Ob2"
    ]
else:
    ccflags = env_homot["CCFLAGS"]
    env_homot["CCFLAGS"] = [
        "-Os" if str(f) in ("-O2", "-O3") else f
        for f in ccflags
    ]

# --- Minimal LIBS: only core + gdscript + holymolly ---
keep_names = {
    "core",
    "module_gdscript",
    "module_holymolly",
}

old_libs = env_homot["LIBS"]
new_libs = []
for lib in old_libs:
    if isinstance(lib, list):
        s = str(lib[0]) if lib else ""
    else:
        s = str(lib)

    is_engine_lib = ".windows." in s and s.endswith(".lib")
    if is_engine_lib:
        keep = any(name + "." in s.replace("\\", "/").split("/")[-1] for name in keep_names)
        if keep:
            new_libs.append(lib)
    else:
        new_libs.append(lib)

env_homot["LIBS"] = new_libs

# ---------------------------------------------------------------------------
# Generate embedded linterdb if the source JSON exists.
# ---------------------------------------------------------------------------

linterdb_json = os.path.join(str(env.Dir("#")), "linter", "linterdb.json")
linterdb_gen_cpp = os.path.join(str(env.Dir("#")), "linter", "linterdb_embedded.gen.cpp")
embed_script = os.path.join(str(env.Dir("#")), "linter", "embed_linterdb.py")

if os.path.exists(linterdb_json):
    # Regenerate if JSON is newer than the generated file.
    needs_regen = not os.path.exists(linterdb_gen_cpp) or \
        os.path.getmtime(linterdb_json) > os.path.getmtime(linterdb_gen_cpp)
    if needs_regen:
        print("Generating embedded linterdb...")
        subprocess.check_call([sys.executable, embed_script, linterdb_json, linterdb_gen_cpp])

if not os.path.exists(linterdb_gen_cpp):
    print("WARNING: linterdb_embedded.gen.cpp not found. Place linterdb.json in linter/ and rebuild.")

# ---------------------------------------------------------------------------
# Source files
# ---------------------------------------------------------------------------

homot_sources = []

# Unified entry point.
env_homot.add_source_files(homot_sources, "homot_main.cpp")

# Linter.
env_homot.add_source_files(homot_sources, "linter_run.cpp")

# Shared workspace utilities.
env_homot.add_source_files(homot_sources, "workspace.cpp")

# Resource (.tscn/.tres) linter.
env_homot.add_source_files(homot_sources, "resource_lint.cpp")

# Shader (.gdshader) linter.
env_homot.add_source_files(homot_sources, "shader_lint.cpp")

# Stubs.
env_homot.add_source_files(homot_sources, "stubs/*.cpp")

# LSP server.
env_homot.add_source_files(homot_sources, "lsp/lsp_transport.cpp")
env_homot.add_source_files(homot_sources, "lsp/lsp_server.cpp")
env_homot.add_source_files(homot_sources, "lsp/lsp_utils.cpp")
env_homot.add_source_files(homot_sources, "lsp/lsp_completion.cpp")
env_homot.add_source_files(homot_sources, "lsp/lsp_signature_help.cpp")
env_homot.add_source_files(homot_sources, "lsp/lsp_definition.cpp")
env_homot.add_source_files(homot_sources, "lsp/lsp_hover.cpp")

# LSPA handlers (query_engine, verifier, formatter — dispatched by the unified server).
env_homot.add_source_files(homot_sources, "lspa/query_engine.cpp")
env_homot.add_source_files(homot_sources, "lspa/formatter.cpp")
env_homot.add_source_files(homot_sources, "lspa/verifier.cpp")

# Embedded linterdb.
env_homot.add_source_files(homot_sources, "linterdb_embedded.gen.cpp")

# Recompile engine source files with HOMOT_LINTER stubs.
engine_override_sources = [
    "core/object/class_db.cpp",
    "core/config/engine.cpp",
    "core/config/project_settings.cpp",
    "core/io/resource_loader.cpp",
    "core/object/script_language.cpp",
    "core/register_core_types.cpp",
    "servers/text/text_server.cpp",
    "servers/text/text_server_extension.cpp",
    "drivers/windows/file_access_windows.cpp",
    "drivers/windows/dir_access_windows.cpp",
]
for src in engine_override_sources:
    obj_base = os.path.splitext(os.path.basename(src))[0]
    target = "override/" + obj_base
    homot_sources.append(env_homot.Object(target, "#" + src))

# Build unified binary.
prog = env_homot.add_program("#bin/linter/homot", homot_sources)

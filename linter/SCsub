#!/usr/bin/env python
"""
SCsub for the standalone GDScript linter.
Produces a separate homot-linter binary that links only the minimum set
of engine libraries. Stub behavior is compiled into the engine source files
via #ifdef HOMOT_LINTER guards, so no /FORCE:MULTIPLE is needed and the
linker can strip unreferenced code (/OPT:REF).

To enable, add to root SConstruct after the platform SCsub line:
    if env.get("linter", False):
        SConscript("linter/SCsub")

Build with:
    scons platform=windows target=template_debug linter=yes
"""
from misc.utility.scons_hints import *

Import("env")

import os

env_linter = env.Clone()

# Define HOMOT_LINTER so the engine source files compile with stub logic.
env_linter.Append(CPPDEFINES=["HOMOT_LINTER"])

# Remove the custom entry point set by the platform build — the linter has
# its own standard main().
linkflags = env_linter["LINKFLAGS"]
if env_linter.msvc:
    env_linter["LINKFLAGS"] = [f for f in linkflags if "ENTRY" not in str(f)]
else:
    env_linter["LINKFLAGS"] = [f for f in linkflags if "--entry" not in str(f)]

# The linter is a console application.
if env_linter.msvc:
    linkflags = env_linter["LINKFLAGS"]
    env_linter["LINKFLAGS"] = [
        "/SUBSYSTEM:CONSOLE" if "SUBSYSTEM:WINDOWS" in str(f) else f
        for f in linkflags
    ]

# --- Linker optimization ---
# /OPT:REF  — remove unreferenced functions/data (works now without /FORCE)
# /OPT:ICF  — fold identical functions
# /DEBUG:NONE — strip all debug info from the linter binary
if env_linter.msvc:
    env_linter["LINKFLAGS"] = [
        f for f in env_linter["LINKFLAGS"]
        if str(f) not in ("/OPT:NOICF", "/OPT:NOREF", "/DEBUG:FULL")
    ]
    env_linter.Append(LINKFLAGS=["/OPT:REF", "/OPT:ICF", "/DEBUG:NONE"])
else:
    env_linter.Append(LINKFLAGS=["-Wl,--gc-sections", "-s"])

# --- Optimize for size ---
if env_linter.msvc:
    ccflags = env_linter["CCFLAGS"]
    env_linter["CCFLAGS"] = [
        "/Os" if (str(f) in ("/O2", "/Ox")) else f
        for f in ccflags
        if str(f) != "/Ob2"
    ]
else:
    ccflags = env_linter["CCFLAGS"]
    env_linter["CCFLAGS"] = [
        "-Os" if str(f) in ("-O2", "-O3") else f
        for f in ccflags
    ]

# --- Minimal LIBS: only core + gdscript + holymolly ---
# servers and drivers are NOT linked as monolithic libs — only the few
# needed source files are compiled directly (see below).
keep_names = {
    "core",
    "module_gdscript",
    "module_holymolly",
}

old_libs = env_linter["LIBS"]
new_libs = []
for lib in old_libs:
    if isinstance(lib, list):
        s = str(lib[0]) if lib else ""
    else:
        s = str(lib)

    is_engine_lib = ".windows." in s and s.endswith(".lib")
    if is_engine_lib:
        keep = any(name + "." in s.replace("\\", "/").split("/")[-1] for name in keep_names)
        if keep:
            new_libs.append(lib)
    else:
        new_libs.append(lib)

env_linter["LIBS"] = new_libs

linter_sources = []

# Compile linter-specific source files.
env_linter.add_source_files(linter_sources, "main_linter.cpp")
env_linter.add_source_files(linter_sources, "linter_run.cpp")
env_linter.add_source_files(linter_sources, "stubs/*.cpp")

# Recompile engine source files that contain #ifdef HOMOT_LINTER stubs.
# These .obj files replace the corresponding members in the engine .lib,
# so the linker uses our stub versions without needing /FORCE:MULTIPLE.
# We compile them with explicit output paths under linter/override/ to
# avoid conflicting with the engine's own .obj files.
engine_override_sources = [
    "core/object/class_db.cpp",
    "core/config/engine.cpp",
    "core/config/project_settings.cpp",
    "core/io/resource_loader.cpp",
    "core/object/script_language.cpp",
    "core/register_core_types.cpp",
    # Only the TextServer files needed (TextServerDummy is header-only):
    "servers/text/text_server.cpp",
    "servers/text/text_server_extension.cpp",
    # Only the platform file/dir access implementations:
    "drivers/windows/file_access_windows.cpp",
    "drivers/windows/dir_access_windows.cpp",
]
for src in engine_override_sources:
    obj_base = os.path.splitext(os.path.basename(src))[0]
    target = "override/" + obj_base
    linter_sources.append(env_linter.Object(target, "#" + src))

# Build as a separate program.
prog = env_linter.add_program("#bin/linter/homot-linter", linter_sources)

# ---------------------------------------------------------------------------
# LSP server binary — same engine bootstrap, different entry point.
# ---------------------------------------------------------------------------

env_lsp = env_linter.Clone()

lsp_sources = []

# LSP-specific source files.
env_lsp.add_source_files(lsp_sources, "lsp/lsp_main.cpp")
env_lsp.add_source_files(lsp_sources, "lsp/lsp_transport.cpp")
env_lsp.add_source_files(lsp_sources, "lsp/lsp_server.cpp")
env_lsp.add_source_files(lsp_sources, "lsp/lsp_utils.cpp")
env_lsp.add_source_files(lsp_sources, "lsp/lsp_completion.cpp")
env_lsp.add_source_files(lsp_sources, "lsp/lsp_signature_help.cpp")
env_lsp.add_source_files(lsp_sources, "lsp/lsp_definition.cpp")
env_lsp.add_source_files(lsp_sources, "lsp/lsp_hover.cpp")

# Reuse stub objects already compiled for the linter (avoid duplicate targets).
lsp_sources += [s for s in linter_sources if "stubs" in str(s)]

# Same engine override sources as the linter.
for src in engine_override_sources:
    obj_base = os.path.splitext(os.path.basename(src))[0]
    target = "lsp_override/" + obj_base
    lsp_sources.append(env_lsp.Object(target, "#" + src))

lsp_prog = env_lsp.add_program("#bin/linter/homot-lsp", lsp_sources)

# Test property access restrictions in sandbox mode
func test():
	print("Testing property access in sandbox")

	# According to design.md, SafeWrapper should check property access
	# Some properties may be blocked based on SandboxConfig

	# Test safe property access
	print("Testing safe property access:")
	var node = Node.new()

	# Safe get operations
	var name = node.name
	print("Got name property: " + str(name))

	# Safe set operations
	node.name = "new_name"
	print("Set name property to: " + str(node.name))

	# Test with custom class
	var custom = CustomClass.new()
	custom.safe_property = 42
	print("Custom safe property: " + str(custom.safe_property))

	node.free()

	print("Property access test completed")

class CustomClass:
	var safe_property: int = 0
	var another_property: String = "test"

	func get_value() -> int:
		return safe_property

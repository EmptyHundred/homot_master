# Test sandbox context isolation
func test():
	print("Testing sandbox context isolation")

	# According to design.md, different scripts can have different sandbox profiles
	# Each SandboxProfile has its own config, limiter, wrapper, and errors
	# Different sandbox_id values create isolated contexts

	print("Simulating multiple sandbox contexts:")

	# Context 1: Strict sandbox (HMScript)
	print("Context 1: Strict sandbox")
	print("- Blocks: OS, FileAccess, DirAccess, Thread")
	print("- Paths: Only res:// and user://")
	print("- Limits: 100 write ops/frame, 10 heavy ops/frame")
	var context1_node = Node.new()
	context1_node.set_name("strict_context")
	print("Context 1 node: " + str(context1_node.name))

	# Context 2: Regular GDScript (no sandbox)
	print("Context 2: Regular GDScript (no sandbox)")
	print("- No restrictions")
	print("- Full engine access")
	var context2_node = Node.new()
	context2_node.set_name("normal_context")
	print("Context 2 node: " + str(context2_node.name))

	# Contexts should not interfere with each other
	print("Contexts are isolated - operations in one don't affect the other")

	context1_node.free()
	context2_node.free()

	print("Context isolation test completed")

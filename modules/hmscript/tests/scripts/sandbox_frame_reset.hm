# Test per-frame counter reset in sandbox mode
func test():
	print("Testing per-frame counter reset")

	# According to design.md, ExecutionLimiter.reset_frame_counters()
	# should be called every frame in GDScriptLanguage::frame()
	# This resets write_ops_this_frame and heavy_ops_this_frame

	print("Frame 1: Performing operations")
	var node = Node.new()
	for i in range(3):
		node.set_name("frame1_" + str(i))
	print("Performed 3 write operations")

	# Simulate frame boundary
	print("--- Frame boundary (counters reset) ---")

	print("Frame 2: Performing operations")
	for i in range(3):
		node.set_name("frame2_" + str(i))
	print("Performed 3 write operations")

	# Without frame reset, we would have 6 total operations
	# With frame reset, each frame starts fresh with 3 operations

	print("Note: Counters reset each frame to allow sustained operation")
	print("without hitting cumulative limits")

	node.free()

	print("Frame reset test completed")
